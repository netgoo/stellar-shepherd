---
import BlogLayout from '../../layouts/BlogLayout.astro';
const postFiles = import.meta.glob('../../content/posts/*.md', { eager: true });

export function getStaticPaths() {
  const paths = [];
  Object.keys(postFiles).forEach(filePath => {
    const fileName = filePath.split('/').pop();
    const slug = fileName.slice(0, -3);
    paths.push({ params: { slug } });
  });
  return paths;
}

const { slug } = Astro.params;
const targetFile = ../../content/posts/.md;
const post = postFiles[targetFile];

if (!post) {
  return <BlogLayout title="文章不存在">
    <p>文章丢失，<a href="/blog">返回笔记列表</a></p>
  </BlogLayout>;
}

const { default: ArticleBody, frontmatter } = post;
const rawDate = frontmatter.date || frontmatter.pubDate;
const dateObj = new Date(rawDate);
const formatDate = ${dateObj.getFullYear()}--;
---

<BlogLayout title={frontmatter.title}>
  <a href="/blog" style="margin-bottom:16px;display:inline-block;color:#0066cc;">← 返回全部笔记</a>
  <h1 style="font-weight:normal;margin:10px 0;">{frontmatter.title}</h1>
  <time style="color:#666;display:block;margin-bottom:30px;">{formatDate}</time>
  <article style="line-height:1.8;font-size:17px;">
    <ArticleBody />
  </article>
</BlogLayout>