---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  console.log('[DEBUG-STEP22] Total posts found:', posts.length);
  
  const paths = posts.map((post) => {
    // е…је®№ .md е’?.mdxпјҢеҗҢж—¶еӨ„зҗҶеҸҜиғҪзҡ„еӯҗзӣ®еҪ•з»“жһ?    const slug = post.id.replace(/\.mdx?$/, '').replace(/^blog\//, '');
    console.log(`[DEBUG-STEP22] Registered slug: "${slug}" (from id: "${post.id}")`);
    return {
      params: { slug },
      props: { post },
    };
  });

  console.log('[DEBUG-STEP22] All registered slugs:', paths.map(p => p.params.slug));
  return paths;
}

const { post } = Astro.props;

// рҹӣЎпё?е…ій”®йҳІеҫЎпјҡеҪ“ slug жңӘеҢ№й…Қж—¶дјҳйӣ…йҷҚзә§
if (!post) {
  console.warn('[DEBUG-STEP22] вҡ пёҸ No post matched for slug:', Astro.params.slug);
  return Astro.redirect('/404');
}
---
<html><body><h1>{post.data.title}</h1></body></html>